---
import { getCollection } from "astro:content";
import ContactCTA from "../components/ContactCTA.astro";
import Grid from "../components/Grid.astro";
import Hero from "../components/Hero.astro";
import MemberPreview from "../components/MemberPreview.astro";
import BaseLayout from "../layouts/BaseLayout.astro";

const members = (await getCollection("members")).sort((a, b) =>
	a.data.title.toLowerCase().localeCompare(b.data.title.toLowerCase()),
);
---

<BaseLayout
	title="Members | JPL Innovation"
	description="Learn about JPL Innovation's members"
>
	<div class="stack gap-20">
		<main class="wrapper stack gap-8">
			<Hero
				title="Members"
				tagline="JPL Innovation is comprised of many smart individuals."
				align="start"
			/>
			<Grid variant="offset">
				{
					members.map((member) => (
						<li>
							<MemberPreview member={member} />
						</li>
					))
				}
			</Grid>
		</main>
		<ContactCTA />
	</div>
</BaseLayout>
